{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3StaticAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::pixel-monitor-storage-bucket",
        "arn:aws:s3:::pixel-monitor-storage-bucket/*"
      ]
    }
  ]
}
